# ─────────────────────────────────────────────────────────────
# ResearchBench AI — Environment Configuration
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Groq (required) — get from https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# LangSmith (strongly recommended) — get from https://smith.langchain.com/settings
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_your_key_here
LANGSMITH_PROJECT=researchbench-ai

# Tavily (required for web search fallback) — get from https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# Semantic Scholar (optional — pipeline falls back to arXiv-only if missing)
# Apply at https://www.semanticsscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# ChromaDB persistence directory (default: ./memory/.chromadb)
CHROMA_PERSIST_DIR=./memory/.chromadb

# Evaluation
EVAL_TEST_QUERIES_PATH=./eval/test_queries.json
EVAL_RESULTS_PATH=./eval/results_log.jsonl

# Retrieval
MAX_PAPERS_PER_QUERY=10
SEMANTIC_SCHOLAR_RPS=0.9
